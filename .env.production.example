# ─────────────────────────────────────────────────────────────────────────────
# Production .env for deploying OUR fork's images (built by
# .github/workflows/build-our-images.yml and pushed to ghcr.io/<owner>).
# Copy to `.env` on the server, fill in the values, then deploy.
# ─────────────────────────────────────────────────────────────────────────────

# Use OUR images instead of the upstream dograh-hq ones. The compose file
# references ${REGISTRY}/dograh-api and ${REGISTRY}/dograh-ui.
REGISTRY=ghcr.io/xerk

# Image tag to run (latest, a short SHA, or a custom tag from workflow_dispatch).
# Compose pins :latest by default; override per-service if you prefer SHAs.
# IMAGE_TAG=latest

# ── Secrets (REQUIRED) ───────────────────────────────────────────────────────
# Strong random hex (e.g. `openssl rand -hex 32`). Auth tokens are signed with it.
OSS_JWT_SECRET=__change_me__
# Shared secret for the coturn TURN server (e.g. `openssl rand -hex 32`).
TURN_SECRET=__change_me__

# ── Public endpoints (set to your server's HTTPS URL / IP) ───────────────────
# Backend URL the browser + webhooks use. For remote/HTTPS set your domain or IP.
BACKEND_API_ENDPOINT=https://your-host
# Public MinIO URL browsers use to fetch audio/recordings.
MINIO_PUBLIC_ENDPOINT=https://your-host:9000
# Host browsers use to reach TURN (your server's public IP or domain).
TURN_HOST=your-host

# ── Scaling / perf ───────────────────────────────────────────────────────────
# uvicorn workers nginx load-balances (≈1 per vCPU, ~300–500MB RAM each).
FASTAPI_WORKERS=4

# ── Misc ─────────────────────────────────────────────────────────────────────
ENABLE_TELEMETRY=false
# POSTGRES_PASSWORD=postgres
